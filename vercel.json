{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "echo Static Hapogea demo ready",
  "outputDirectory": "hapogea-preview",
  "framework": null,
  "installCommand": "echo skip",
  "functions": {
    "api/winner-feed.js": { "maxDuration": 30 },
    "api/cron.js": { "maxDuration": 30 },
    "api/winner-cron.js": { "maxDuration": 30 },
    "api/winner-cron-midnight.js": { "maxDuration": 30 },
    "api/recommendation-bot.js": { "maxDuration": 60 },
    "api/recommendation-stats.js": { "maxDuration": 30 },
    "api/debug-odds.js": { "maxDuration": 60 }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/recommendation-bot", "schedule": "*/30 * * * *" }
  ]
}
