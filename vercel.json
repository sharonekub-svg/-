{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "echo Static Hapogea demo ready",
  "outputDirectory": "hapogea-preview",
  "framework": null,
  "installCommand": "echo skip",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/winner-cron", "schedule": "0 */2 * * *" },
    { "path": "/api/winner-cron-midnight", "schedule": "5 21 * * *" }
  ]
}
